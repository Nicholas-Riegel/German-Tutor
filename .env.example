# German Tutor Configuration
# Copy this file to .env and adjust the settings for your environment

# Database Configuration
DATABASE_PATH=~/.german-tutor/conversations.db
AUDIO_STORAGE_PATH=~/.german-tutor/audio/
MODEL_STORAGE_PATH=~/.german-tutor/models/

# Model Configuration
PRIMARY_MODEL=openeurollm-german:7b
FALLBACK_MODEL=smollm2-german:360m
MAX_CONVERSATION_LENGTH=100

# Audio Settings
AUDIO_FORMAT=wav
SAMPLE_RATE=16000
RECORDING_TIMEOUT_SECONDS=30
MAX_AUDIO_FILE_SIZE_MB=50
MAX_AUDIO_DURATION_MINUTES=5

# API Settings
BACKEND_HOST=localhost
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Performance Settings
MAX_MEMORY_USAGE_GB=12
ENABLE_GPU_ACCELERATION=true

# Security Settings
ENABLE_CONTENT_FILTERING=true
MAX_RESPONSE_LENGTH=500

# Development Settings
DEBUG=true
LOG_LEVEL=INFO
ENABLE_CORS=true

# Data Retention
CONVERSATION_RETENTION_DAYS=30
AUDIO_CLEANUP_HOURS=24